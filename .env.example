# Base URL of the branor-os API (no trailing slash).
BRANOR_API_BASE_URL=https://api.branor.com.br
# Internal alternative when this MCP runs alongside branor-api in the same
# Docker network (Coolify): BRANOR_API_BASE_URL=http://branor-api:3000

# Optional: override API prefix (defaults to /api/v1, matching the NestJS app).
BRANOR_API_PREFIX=/api/v1

# --- stdio entrypoint (dist/index.js — local dev only) ---
# Org-scoped API key (format ak_<prefix>_<secret>). In HTTP mode this is NOT
# read from env — it comes from the connection's `Authorization: Bearer`
# header instead (see below). Every tool call carries its own
# workspace_public_id argument (multi-tenant, per-call identity), injected
# centrally by src/server.ts.
BRANOR_API_KEY=ak_xxx_xxx

# --- HTTP transport (entrypoint dist/http.js — deploy remoto) ---
# Deixe estas vars vazias/ausentes para o modo stdio local (dist/index.js).
#
# Não há "bearer de fachada" nem workspace fixo por conexão. A própria API
# key do branor-os é o portão: o agente remoto conecta com
# `Authorization: Bearer <apiKey>` (uma key org-scoped) e essa key vira a
# credencial da sessão inteira. O workspace chega em CADA tools/call como o
# argumento `workspace_public_id` (injetado centralmente em todas as tools —
# ver src/server.ts) — nunca como estado da sessão.

# Porta HTTP (default 8080). No Coolify normalmente a env PORT é injetada.
PORT=8080

# Host de bind (default 0.0.0.0 — necessário dentro de container).
HOST=0.0.0.0

# Path do endpoint MCP (default /mcp).
MCP_PATH=/mcp
