{
  "name": "branor-os-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing curated tools over the branor-os marketing/ads API.",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "bin": {
    "branor-os-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.20.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.1",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4",
    "eslint": "9.39.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.2.0"
}
